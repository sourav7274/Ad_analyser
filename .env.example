# Application settings — copy this file to .env and fill in your values
# All variables have sensible defaults and are optional unless noted.

# Host address the server binds to
HOST=0.0.0.0

# Port the server listens on
PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Number of Uvicorn worker processes
WORKERS=1

# Size of the ThreadPoolExecutor used to offload the blocking ML model call
EXECUTOR_THREADS=4

# Timeout in seconds for a single model inference call (0 = no timeout)
MODEL_TIMEOUT=30
